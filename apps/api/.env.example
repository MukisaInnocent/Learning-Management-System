# ─── Database ────────────────────────────────────────────────────────────────
# SQLite (testing / Render free tier) — data resets on each redeploy:
DATABASE_URL="file:./dev.db"
# PostgreSQL (production) — URL-encode special chars: @ → %40
# DATABASE_URL="postgresql://edu_admin:YOUR_PASSWORD@127.0.0.1:5432/edu_platform"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL="http://localhost:3000"
# Production: FRONTEND_URL="https://edu-web.onrender.com"
